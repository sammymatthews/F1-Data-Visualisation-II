{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": "container",
    "height": "container",
    "autosize": {
        "type": "fit",
        "contains": "padding"
    },
    "background": "transparent",
    "projection": {
        "type": "equalEarth"
    },
    "config": {
        "title": {
            "color": "white"
        },
        "axis": {
            "domainColor": "white",
            "labelColor": "white",
            "tickColor": "white",
            "titleColor": "white"
        },
        "legend": {
            "titleColor": "white",
            "labelColor": "white"
        }
    },
    "params": [
        {
            "name": "toggle_incoming",
            "value": true,
            "bind": {
                "input": "checkbox",
                "name": "Show Incoming Flows: "
            }
        },
        {
            "name": "toggle_outgoing",
            "value": true,
            "bind": {
                "input": "checkbox",
                "name": "Show Outgoing Flows: "
            }
        }
    ],
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/ne_110m.json",
                "format": {
                    "type": "topojson",
                    "feature": "ne_110m_admin_0_countries"
                }
            },
            "mark": {
                "type": "geoshape",
                "fill": "#50657f46",
                "stroke": "white",
                "strokeOpacity": 0.6
            }
        },
        {
            "data": {
                "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/circuits.csv",
                "format": {
                    "type": "csv"
                }
            },
            "params": [
                {
                    "name": "highlight",
                    "select": {
                        "type": "point",
                        "on": "pointerover",
                        "nearest": true,
                        "fields": [
                            "circuitId"
                        ]
                    }
                }
            ],
            "mark": {
                "type": "circle",
                "color": "lightskyblue",
                "size": 40
            },
            "encoding": {
                "longitude": {
                    "field": "lng",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "lat",
                    "type": "quantitative"
                }
            }
        },
        {
            "data": {
                "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/circuit_flows.csv",
                "format": {
                    "type": "csv"
                }
            },
            "transform": [
                {
                    "filter": "highlight.circuitId == datum.circuitId"
                },
                {
                    "lookup": "circuitId",
                    "from": {
                        "data": {
                            "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/circuits.csv",
                            "format": {
                                "type": "csv"
                            }
                        },
                        "key": "circuitId",
                        "fields": [
                            "name"
                        ]
                    },
                    "as": "originCircuit"
                },
                {
                    "lookup": "next_circuit",
                    "from": {
                        "data": {
                            "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/circuits.csv",
                            "format": {
                                "type": "csv"
                            }
                        },
                        "key": "circuitId",
                        "fields": [
                            "name"
                        ]
                    },
                    "as": "destinationCircuit"
                },
                {
                    "calculate": "toggle_outgoing ? 0.8 : 0",
                    "as": "opacity"
                },
                {
                    "calculate": "'Outgoing'",
                    "as": "direction"
                }
            ],
            "mark": {
                "type": "rule",
                "strokeCap": "round"
            },
            "encoding": {
                "longitude": {
                    "field": "lng",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "lat",
                    "type": "quantitative"
                },
                "longitude2": {
                    "field": "next_lng",
                    "type": "quantitative"
                },
                "latitude2": {
                    "field": "next_lat",
                    "type": "quantitative"
                },
                "color": {
                    "value": "#e16059",
                    "legend": true
                },
                "color": {
                    "field": "direction",
                    "type": "nominal",
                    "scale": {
                        "domain": [
                            "Outgoing",
                            "Incoming"
                        ],
                        "range": [
                            "#e16059",
                            "#fed55b"
                        ]
                    },
                    "legend": {
                        "title": "Flow Direction"
                    }
                },
                "size": {
                    "field": "transition_count",
                    "type": "quantitative",
                    "scale": {
                        "type": "threshold",
                        "domain": [
                            2,
                            5,
                            10
                        ],
                        "range": [
                            0.8,
                            2,
                            4
                        ]
                    },
                    "legend": {
                        "title": "Times Traveled"
                    }
                },
                "strokeOpacity": {
                    "field": "opacity",
                    "type": "quantitative",
                    "scale": null
                },
                "tooltip": [
                    {
                        "field": "originCircuit",
                        "title": "From "
                    },
                    {
                        "field": "destinationCircuit",
                        "title": "To "
                    },
                    {
                        "field": "transition_count",
                        "title": "Total flow"
                    }
                ]
            }
        },
        {
            "data": {
                "url": "../f1-data/circuit_flows.csv",
                "format": {
                    "type": "csv"
                }
            },
            "transform": [
                {
                    "filter": "highlight.circuitId == datum.next_circuit"
                },
                {
                    "lookup": "circuitId",
                    "from": {
                        "data": {
                            "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/circuits.csv",
                            "format": {
                                "type": "csv"
                            }
                        },
                        "key": "circuitId",
                        "fields": [
                            "name"
                        ]
                    },
                    "as": "originCircuit"
                },
                {
                    "lookup": "next_circuit",
                    "from": {
                        "data": {
                            "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/circuits.csv",
                            "format": {
                                "type": "csv"
                            }
                        },
                        "key": "circuitId",
                        "fields": [
                            "name"
                        ]
                    },
                    "as": "destinationCircuit"
                },
                {
                    "calculate": "toggle_incoming ? 0.8 : 0",
                    "as": "opacity"
                },
                {
                    "calculate": "'Incoming'",
                    "as": "direction"
                }
            ],
            "mark": {
                "type": "rule",
                "strokeCap": "round",
                "strokeDash": [
                    8,
                    4
                ]
            },
            "encoding": {
                "longitude": {
                    "field": "lng",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "lat",
                    "type": "quantitative"
                },
                "longitude2": {
                    "field": "next_lng",
                    "type": "quantitative"
                },
                "latitude2": {
                    "field": "next_lat",
                    "type": "quantitative"
                },
                "size": {
                    "field": "transition_count",
                    "type": "quantitative",
                    "scale": {
                        "type": "threshold",
                        "domain": [
                            2,
                            5,
                            10
                        ],
                        "range": [
                            0.8,
                            2,
                            4
                        ]
                    },
                    "legend": {
                        "title": "Times Traveled"
                    }
                },
                "color": {
                    "field": "direction",
                    "type": "nominal",
                    "scale": {
                        "domain": [
                            "Outgoing",
                            "Incoming"
                        ],
                        "range": [
                            "#e16059",
                            "#fed55b"
                        ]
                    },
                    "legend": {
                        "title": "Flow Direction"
                    }
                },
                "strokeOpacity": {
                    "field": "opacity",
                    "type": "quantitative",
                    "scale": null
                },
                "tooltip": [
                    {
                        "field": "originCircuit",
                        "title": "From "
                    },
                    {
                        "field": "destinationCircuit",
                        "title": "To "
                    },
                    {
                        "field": "transition_count",
                        "title": "Total flow"
                    }
                ]
            }
        }
    ]
}

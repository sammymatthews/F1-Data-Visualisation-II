{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Accumulation of Wins across Seasons by Top Constructors",
    "width": "container",
    "height": "container",
    "autosize": {
        "type": "fit"
    },
    "background": "transparent",
    "config": {
        "title": {
            "color": "white"
        },
        "axis": {
            "domainColor": "white",
            "labelColor": "white",
            "tickColor": "white",
            "titleColor": "white"
        },
        "legend": {
            "titleColor": "white",
            "labelColor": "white"
        }
    },
    "data": {
        "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/results.csv",
        "format": {
            "type": "csv"
        }
    },
    "transform": [
        {
            "lookup": "constructorId",
            "from": {
                "data": {
                    "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/constructors.csv"
                },
                "key": "constructorId",
                "fields": [
                    "name"
                ]
            },
            "as": [
                "constructorName"
            ]
        },
        {
            "lookup": "raceId",
            "from": {
                "data": {
                    "url": "https://raw.githubusercontent.com/sammymatthews/F1-Data-Visualisation-II/refs/heads/main/f1-data/races.csv"
                },
                "key": "raceId",
                "fields": [
                    "year"
                ]
            }
        },
        {
            "filter": "datum.positionOrder == 1"
        },
        {
            "calculate": "1",
            "as": "winCounter"
        },
        {
            "joinaggregate": [
                {
                    "op": "sum",
                    "field": "winCounter",
                    "as": "totalWins"
                }
            ],
            "groupby": [
                "constructorName"
            ]
        },
        {
            "window": [
                {
                    "op": "dense_rank",
                    "as": "constructorRank"
                }
            ],
            "sort": [
                {
                    "field": "totalWins",
                    "order": "descending"
                }
            ]
        },
        {
            "filter": "datum.constructorRank <= 5"
        },
        {
            "aggregate": [
                {
                    "op": "sum",
                    "field": "winCounter",
                    "as": "winsPerYear"
                }
            ],
            "groupby": [
                "constructorName",
                "year"
            ]
        },
        {
            "window": [
                {
                    "op": "sum",
                    "field": "winsPerYear",
                    "as": "cumulativeWins"
                }
            ],
            "sort": [
                {
                    "field": "year",
                    "order": "ascending"
                }
            ],
            "groupby": [
                "constructorName"
            ],
            "frame": [
                null,
                0
            ]
        }
    ],
    "encoding": {
        "x": {
            "scale": {
                "domain": [
                    1950,
                    2024
                ]
            }
        }
    },
    "layer": [
        {
            "mark": {
                "type": "line"
            },
            "encoding": {
                "y": {
                    "field": "cumulativeWins",
                    "type": "quantitative",
                    "title": "Accumulated Grand Prix Wins"
                },
                "x": {
                    "field": "year",
                    "type": "quantitative",
                    "title": "Year",
                    "axis": {
                        "format": "d",
                        "tickMinStep": 10,
                        "labelAngle": 0
                    }
                },
                "color": {
                    "field": "constructorName",
                    "scale": {
                        "range": [
                            "#e45756",
                            "#f58518",
                            "#72b7b2",
                            "#4c78a8",
                            "#54a24b"
                        ]
                    },
                    "legend": {
                        "title": "Constructor Name"
                    }
                },
                "tooltip": [
                    {
                        "field": "totalWins",
                        "title": "Total Grand Prix wins"
                    },
                    {
                        "field": "constructorName",
                        "title": "Constructor"
                    }
                ]
            }
        },
        {
            "params": [
                {
                    "name": "hover",
                    "select": {
                        "type": "point",
                        "fields": [
                            "year"
                        ],
                        "nearest": true,
                        "on": "pointerover",
                        "clear": "pointerout"
                    }
                }
            ],
            "mark": {
                "type": "circle",
                "size": 20,
                "opacity": 0,
                "stroke": "transparent"
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "quantitative"
                },
                "y": {
                    "field": "cumulativeWins",
                    "type": "quantitative"
                },
                "tooltip": [
                    {
                        "field": "year",
                        "type": "quantitative",
                        "title": "Season",
                        "format": "d"
                    },
                    {
                        "field": "constructorName",
                        "type": "nominal",
                        "title": "Constructor Team"
                    },
                    {
                        "field": "winsPerYear",
                        "type": "quantitative",
                        "title": "Wins This Year"
                    },
                    {
                        "field": "cumulativeWins",
                        "type": "quantitative",
                        "title": "Running Total Wins"
                    }
                ],
                "color": {
                    "field": "constructorName"
                }
            }
        },
        {
            "transform": [
                {
                    "filter": {
                        "param": "hover",
                        "empty": false
                    }
                }
            ],
            "mark": {
                "type": "rule",
                "color": "#9ca3af",
                "strokeWidth": 1.5,
                "strokeDash": [
                    4,
                    4
                ]
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "quantitative"
                }
            }
        },
        {
            "transform": [
                {
                    "filter": {
                        "param": "hover",
                        "empty": false
                    }
                }
            ],
            "mark": {
                "type": "circle",
                "size": 70,
                "stroke": "white",
                "strokeWidth": 1.5,
                "opacity": 1
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "quantitative"
                },
                "y": {
                    "field": "cumulativeWins",
                    "type": "quantitative"
                },
                "color": {
                    "field": "constructorName",
                    "type": "nominal"
                }
            }
        }
    ]
}

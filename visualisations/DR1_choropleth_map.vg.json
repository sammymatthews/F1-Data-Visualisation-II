{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Proportion of F1 Driver Nationalities",
    "width": "container",
    "height": "container",
    "autosize": {
        "type": "fit"
    },
    "background": "transparent",
    "config": {
        "title": {
            "color": "white"
        },
        "axis": {
            "domainColor": "white",
            "labelColor": "white",
            "tickColor": "white",
            "titleColor": "white"
        },
        "legend": {
            "titleColor": "white",
            "labelColor": "white"
        }
    },
    "projection": {
        "type": "equalEarth"
    },
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/sammymatthews/fit2179/refs/heads/main/f1-data/ne_110m.json",
                "format": {
                    "type": "topojson",
                    "feature": "ne_110m_admin_0_countries"
                }
            },
            "mark": {
                "type": "geoshape",
                "fill": "#50657f46",
                "stroke": "white",
                "strokeOpacity": 0.6
            }
        },
        {
            "data": {
                "url": "https://raw.githubusercontent.com/sammymatthews/fit2179/refs/heads/main/f1-data/ne_110m.json",
                "format": {
                    "type": "topojson",
                    "feature": "ne_110m_admin_0_countries"
                }
            },
            "transform": [
                {
                    "lookup": "properties.NAME",
                    "from": {
                        "data": {
                            "url": "https://raw.githubusercontent.com/sammymatthews/fit2179/refs/heads/main/f1-data/country_counts.csv"
                        },
                        "key": "country",
                        "fields": [
                            "country",
                            "driver_count"
                        ]
                    }
                },
                {
                    "joinaggregate": [
                        {
                            "op": "sum",
                            "field": "driver_count",
                            "as": "totalDrivers"
                        }
                    ]
                },
                {
                    "calculate": "datum.driver_count / datum.totalDrivers",
                    "as": "proportion"
                },
                {
                    "filter": "datum.proportion > 0"
                }
            ],
            "mark": {
                "type": "geoshape",
                "stroke": "lightgray"
            },
            "encoding": {
                "color": {
                    "field": "proportion",
                    "type": "quantitative",
                    "scale": {
                        "domain": [0,0.2],
                        "scheme": "teals"
                    }
                },
                "tooltip": [
                    {
                        "field": "country",
                        "title": "Country"
                    },
                    {
                        "field": "driver_count",
                        "title": "Driver Count"
                    },
                    {
                        "field": "proportion",
                        "title": "Driver Proportion",
                        "format": ".1%"
                    }
                ]
            }
        }
    ]
}
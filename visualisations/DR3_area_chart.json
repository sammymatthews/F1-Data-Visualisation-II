{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Proportion of Continent Representation in Drivers per Season",
    "width": "container",
    "height": "container",
    "autosize": {
        "type": "fit"
    },
    "background": "transparent",
    "data": {
        "url": "https://raw.githubusercontent.com/sammymatthews/fit2179/refs/heads/main/f1-data/results.csv",
        "format": {
            "type": "csv"
        }
    },
    "config": {
        "title": {
            "color": "white"
        },
        "axis": {
            "domainColor": "white",
            "labelColor": "white",
            "tickColor": "white",
            "titleColor": "white"
        },
        "legend": {
            "titleColor": "white",
            "labelColor": "white"
        }
    },
    "transform": [
        {
            "lookup": "raceId",
            "from": {
                "data": {
                    "url": "https://raw.githubusercontent.com/sammymatthews/fit2179/refs/heads/main/f1-data/races.csv"
                },
                "key": "raceId",
                "fields": [
                    "year"
                ]
            }
        },
        {
            "lookup": "driverId",
            "from": {
                "data": {
                    "url": "./f1-data/drivers_cleaned.csv"
                },
                "key": "driverId",
                "fields": [
                    "Continent"
                ]
            }
        },
        {
            "window": [
                {
                    "op": "row_number",
                    "as": "rowNum"
                }
            ],
            "groupby": [
                "year",
                "driverId"
            ]
        },
        {
            "filter": "datum.rowNum == 1"
        },
        {
            "aggregate": [
                {
                    "op": "count",
                    "as": "continentCount"
                }
            ],
            "groupby": [
                "year",
                "Continent"
            ]
        },
        {
            "joinaggregate": [
                {
                    "op": "sum",
                    "field": "continentCount",
                    "as": "yearTotal"
                }
            ],
            "groupby": [
                "year"
            ]
        },
        {
            "calculate": "datum.yearTotal > 0 ? datum.continentCount / datum.yearTotal : 0",
            "as": "proportion"
        }
    ],
    "mark": "area",
    "encoding": {
        "x": {
            "field": "year",
            "type": "quantitative",
            "axis": {
                "format": "d",
                "tickMinStep": 1
            },
            "scale": {
                "domain": [
                    1950,
                    2024
                ]
            }
        },
        "y": {
            "field": "proportion",
            "type": "quantitative",
            "axis": {
                "format": "%"
            },
            "scale": {
                "domain": [
                    0,
                    1
                ]
            },
            "title": "Proportion of Drivers",
            "impute": {
                "value": 0
            }
        },
        "color": {
            "field": "Continent",
            "type": "nominal",
            "sort": {
                "field": "proportion",
                "order": "descending"
            }
        }
    }
}